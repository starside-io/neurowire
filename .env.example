# Publish credentials for Neurowire. Copy this file to .env and fill it in.
# .env is gitignored and must never be committed. Do not paste a token into any
# tracked file (this .example included): only into your local .env.

# npm token used to publish @neurowire/* to https://registry.npmjs.org.
#
# Create one (recommended: a Granular Access Token) at:
#   https://www.npmjs.com/settings/crimson-med/tokens
#     - Token type:           Granular Access Token
#     - Packages and scopes:  Read and write  ->  scope @neurowire
#     - Organizations:        neurowire  ->  Read and write (optional, for org admin)
#
# Then set it below (value looks like npm_XXXXXXXXXXXXXXXXXXXX):
NPM_TOKEN=
