{
  "name": "@neurowire/web",
  "version": "0.2.0",
  "description": "Render a Neurowire feed or mesh into a self-contained HTML news page.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "neurowire-web": "./dist/cli.js"
  },
  "files": ["dist", "CHANGELOG.md"],
  "keywords": [
    "neurowire",
    "feed",
    "html",
    "static-site",
    "news",
    "page-generator",
    "mesh",
    "atom"
  ],
  "author": "Médéric Burlet <mederic.burlet@gmail.com>",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/starside-io/neurowire.git",
    "directory": "packages/web"
  },
  "homepage": "https://github.com/starside-io/neurowire#readme",
  "bugs": {
    "url": "https://github.com/starside-io/neurowire/issues"
  },
  "engines": {
    "node": ">=24"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli.ts",
    "typecheck": "tsc --noEmit",
    "prepack": "tsup"
  },
  "dependencies": {
    "@neurowire/core": "workspace:*",
    "@neurowire/ingest": "workspace:*",
    "@neurowire/taps": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
