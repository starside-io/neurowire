{
  "name": "@neurowire/ingest",
  "version": "0.5.1",
  "description": "Fetch, detect, and parse RSS/Atom/RDF/JSON feeds and HTML pages into the Neurowire model.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "keywords": [
    "neurowire",
    "feed",
    "rss",
    "atom",
    "rdf",
    "json-feed",
    "feed-parser",
    "rss-parser",
    "scraper",
    "cheerio"
  ],
  "author": "Médéric Burlet <mederic.burlet@gmail.com>",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/starside-io/neurowire.git",
    "directory": "packages/ingest"
  },
  "homepage": "https://github.com/starside-io/neurowire#readme",
  "bugs": {
    "url": "https://github.com/starside-io/neurowire/issues"
  },
  "engines": {
    "node": ">=24"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepack": "tsup"
  },
  "dependencies": {
    "@neurowire/core": "workspace:*",
    "cheerio": "^1.0.0",
    "fast-xml-parser": "^4.5.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3"
  }
}
