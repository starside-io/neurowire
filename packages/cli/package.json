{
  "name": "@neurowire/cli",
  "version": "0.5.0",
  "description": "Neurowire command-line tool: turn any blog, feed, or mesh into Atom, JSON Feed, Markdown, or nwf.",
  "type": "module",
  "bin": {
    "neurowire": "./dist/index.js"
  },
  "files": ["dist", "CHANGELOG.md"],
  "keywords": [
    "neurowire",
    "cli",
    "feed",
    "rss",
    "atom",
    "json-feed",
    "markdown",
    "nwf",
    "mesh"
  ],
  "author": "Médéric Burlet <mederic.burlet@gmail.com>",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/starside-io/neurowire.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/starside-io/neurowire#readme",
  "bugs": {
    "url": "https://github.com/starside-io/neurowire/issues"
  },
  "engines": {
    "node": ">=24"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "prepack": "tsup"
  },
  "dependencies": {
    "@neurowire/core": "workspace:*",
    "@neurowire/ingest": "workspace:*",
    "@neurowire/taps": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
