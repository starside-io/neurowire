{
  "name": "neurowire",
  "version": "0.7.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "build": "pnpm -r build",
    "clean": "rm -rf packages/*/dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:live": "NEUROWIRE_LIVE=1 vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "pnpm -r typecheck",
    "lint": "biome check .",
    "format": "biome format --write .",
    "cli": "tsx packages/cli/src/index.ts",
    "validate": "tsx packages/cli/src/index.ts validate",
    "page": "tsx packages/web/src/cli.ts",
    "docs": "tsx scripts/build-docs.ts",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "api": "pnpm --filter @neurowire/api dev",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@changesets/cli": "^2.27.0",
    "@neurowire/core": "workspace:*",
    "@neurowire/taps": "workspace:*",
    "@neurowire/web": "workspace:*",
    "@types/node": "^22.10.5",
    "@vitest/coverage-v8": "3.2.6",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitepress": "^1.6.4",
    "vitest": "^3.0.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "@biomejs/biome"
    ]
  }
}
